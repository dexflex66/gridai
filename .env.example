# GridAI Band integration — copy to .env and fill in real values. NEVER commit .env.
# One Band agent API key per agent (from the Band platform).
BAND_FORECASTER_API_KEY=band_a_xxx
BAND_COORDINATOR_API_KEY=band_a_xxx
BAND_COMPLIANCE_API_KEY=band_a_xxx
BAND_OPERATOR_API_KEY=band_a_xxx

# Optional: override the Band REST base URL (defaults to https://app.band.ai).
# THENVOI_REST_URL=https://app.band.ai

# Flip the agent runner / chain onto the real platform. Unset/false => MockBand.
# USE_REAL_BAND=true
